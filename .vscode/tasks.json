{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Kill UnrealEditor",
            "type": "shell",
            "command": "Stop-Process -Name 'UnrealEditor' -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 2",
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Build ProjectChaos",
            "type": "shell",
            "command": "& 'C:\\Program Files\\Epic Games\\UE_5.7\\Engine\\Build\\BatchFiles\\Build.bat' ProjectChaosEditor Win64 Development 'C:\\Users\\Apsisx\\Documents\\Unreal Projects\\ProjectChaos\\ProjectChaos.uproject' -waitmutex",
            "dependsOn": "Kill UnrealEditor",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Launch UnrealEditor",
            "type": "shell",
            "command": "Start-Process 'C:\\Program Files\\Epic Games\\UE_5.7\\Engine\\Binaries\\Win64\\UnrealEditor.exe' -ArgumentList '\"C:\\Users\\Apsisx\\Documents\\Unreal Projects\\ProjectChaos\\ProjectChaos.uproject\"'",
            "dependsOn": "Build ProjectChaos",
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Build and Launch UE",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Kill UnrealEditor",
                "Build ProjectChaos",
                "Launch UnrealEditor"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
